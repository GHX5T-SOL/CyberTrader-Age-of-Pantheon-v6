{
  "expo": {
    "name": "CyberTrader",
    "slug": "cybertrader-age-of-pantheon",
    "scheme": "cybertrader",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#050608",
    "newArchEnabled": true,
    "icon": "./assets/brand/icon.png",
    "splash": {
      "image": "./assets/brand/splash.png",
      "backgroundColor": "#050608",
      "resizeMode": "contain"
    },
    "ios": {
      "icon": "./assets/brand/icon.png",
      "supportsTablet": false,
      "bundleIdentifier": "ai.cybertrader.app"
    },
    "android": {
      "package": "ai.cybertrader.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-icon.png",
        "backgroundColor": "#050608"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/brand/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "USE_SUPABASE": false,
      "supabaseUrl": "https://your-project.supabase.co",
      "supabaseAnonKey": "your-anon-key",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b024b715-6718-4854-b318-c6afbb8788e6"
      }
    },
    "owner": "ghxstxbt"
  }
}
