{
  "cli": {
    "version": ">= 16.0.1",
    "appVersionSource": "remote",
    "requireCommit": true
  },
  "build": {
    "base": {
      "node": "20.18.1",
      "env": {
        "EXPO_PUBLIC_USE_SUPABASE_AUTHORITY": "false"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "preview-simulator": {
      "extends": "base",
      "environment": "preview",
      "ios": {
        "simulator": true
      }
    },
    "internal": {
      "extends": "base",
      "distribution": "internal",
      "environment": "preview",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      }
    },
    "store": {
      "extends": "base",
      "distribution": "store",
      "environment": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production": {
      "extends": "store"
    }
  }
}
