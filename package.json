{
  "name": "cybertrader-mobile",
  "version": "0.1.0-phase0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "health:live": "node scripts/check-live-deployment.mjs",
    "qa:responsive": "npm run build:web && playwright test qa/responsive-captures.spec.ts --browser=chromium --reporter=line",
    "safety:autonomous": "node scripts/check-autonomous-safety.mjs",
    "ship:check": "npm run safety:autonomous && npm run typecheck && npm test -- --runInBand && npm run build:web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "replay:economy": "ORACLE_REPLAY_LOG=1 jest engine/__tests__/economy-replay.test.ts --runInBand",
    "tuning:launch": "ORACLE_LAUNCH_TUNING_LOG=1 jest engine/__tests__/launch-tuning.test.ts --runInBand"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@supabase/supabase-js": "^2.104.1",
    "expo": "~52.0.0",
    "expo-av": "~15.0.2",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.1",
    "expo-linear-gradient": "~14.0.2",
    "expo-router": "~4.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "^18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "^0.19.13",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.4.0"
  }
}
