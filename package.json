{
  "name": "cybertrader-mobile",
  "version": "0.1.0-phase0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "capture:screenshots": "npm run build:web && node scripts/capture-screenshot-presets.mjs",
    "start": "expo start",
    "ios": "expo start --ios",
    "android": "expo start --android",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "health:live": "node scripts/check-live-deployment.mjs",
    "qa:responsive": "npm run build:web && playwright test qa/responsive-captures.spec.ts --browser=chromium --reporter=line",
    "qa:axiom": "npm run build:web && playwright test qa/axiom-web-regression.spec.ts --browser=chromium --reporter=line",
    "qa:axiom:live": "playwright test qa/axiom-web-regression.spec.ts --grep '2.8 live' --browser=chromium --reporter=line",
    "qa:smoke": "npm run build:web && playwright test qa/axiom-web-regression.spec.ts --grep axiom-p1-004 --browser=chromium --reporter=line",
    "perf:budgets": "npm run build:web && node scripts/check-performance-budgets.mjs",
    "safety:autonomous": "node scripts/check-autonomous-safety.mjs",
    "ship:check": "npm run safety:autonomous && npm run typecheck && npm test -- --runInBand && npm run build:web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "replay:economy": "ORACLE_REPLAY_LOG=1 jest engine/__tests__/economy-replay.test.ts --runInBand",
    "tuning:launch": "ORACLE_LAUNCH_TUNING_LOG=1 jest engine/__tests__/launch-tuning.test.ts --runInBand",
    "stress:economy": "ORACLE_STRESS_LOG=1 jest engine/__tests__/economy-stress.test.ts --runInBand",
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "optimize:assets:apply": "node scripts/optimize-assets.mjs --apply",
    "endurance:economy": "ORACLE_ENDURANCE_LOG=1 jest engine/__tests__/economy-endurance.test.ts --runInBand",
    "archetypes:report": "ORACLE_ARCHETYPES_LOG=1 jest engine/__tests__/player-archetypes.test.ts --runInBand",
    "tuning:beta": "ORACLE_BETA_TUNING_LOG=1 jest engine/__tests__/beta-tuning.test.ts --runInBand",
    "limit-orders:check": "jest engine/__tests__/limit-orders.test.ts --runInBand",
    "swarm:market": "HYDRA_SWARM_LOG=1 jest engine/__tests__/market-swarm.test.ts --runInBand",
    "retention:beta": "HYDRA_RETENTION_LOG=1 jest engine/__tests__/retention-scenarios.test.ts --runInBand",
    "generate:brand": "python3 scripts/generate-brand-assets.py",
    "provenance:assets": "node scripts/generate-asset-provenance.mjs",
    "provenance:assets:check": "node scripts/generate-asset-provenance.mjs --check",
    "regression:check": "node scripts/regression-monitor.mjs --force",
    "regression:monitor": "node scripts/regression-monitor.mjs"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@supabase/supabase-js": "^2.104.1",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^3.1.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "^5.4.0"
  }
}
